APP_NAME="iStudio by UFicon"
APP_ENV=production
APP_KEY=base64:REPLACE_WITH_PRODUCTION_KEY
APP_DEBUG=false
APP_URL=https://admin-dapp.uficon.com
ASSET_URL=https://admin-dapp.uficon.com

APP_LOCALE=th
APP_FALLBACK_LOCALE=en

# DB — production
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=uficon_dapp_prod
DB_USERNAME=postgres
DB_PASSWORD=

# Cache / Session
CACHE_STORE=database
SESSION_DRIVER=database

# *** All secrets must be set on Coolify environment variables ***
